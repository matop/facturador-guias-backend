            "body": {
              "mode": "raw",
              "raw": "{\n  \"reglaidl\": \"por_comuna\",\n  \"regladescripcion\": \"Agrupar por comuna de destino\",\n  \"fn\": \"extraeTagLista\",\n  \"reglaTags\": [\"CmnaRecep\", \"DirRecep\"]\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
