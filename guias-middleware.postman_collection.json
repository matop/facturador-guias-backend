            "url": {
              "raw": "{{baseUrl}}/reglas/:id",
              "host": ["{{baseUrl}}"],
              "path": ["reglas", ":id"],
              "variable": [{ "key": "id", "value": "por_comuna" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"regladescripcion\": \"Nueva descripcion\",\n  \"fn\": \"extraeTagLista\",\n  \"reglaTags\": [\"CmnaRecep\"]\n}",
              "options": { "raw": { "language": "json" } }
            }
